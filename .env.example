# S3-compatible storage.
# AWS S3:
# S3_REGION=us-east-1
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false
#
# Cloudflare R2:
# S3_REGION=auto
# S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# S3_FORCE_PATH_STYLE=true
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_FORCE_PATH_STYLE=true

# Optional Supabase adapter.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
